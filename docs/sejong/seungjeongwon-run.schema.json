{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/sejong/seungjeongwon-run.schema.json",
  "title": "Seungjeongwon Active Run Schema Draft",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "sejong.seungjeongwon-run/v0.1-draft"
    },
    "run_id": {
      "$ref": "#/$defs/NonEmptyString"
    },
    "repo_root": {
      "$ref": "#/$defs/NonEmptyString"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "goal": {
      "$ref": "#/$defs/NonEmptyString"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "blocked",
        "invalidated",
        "failed"
      ]
    },
    "success_criteria": {
      "$ref": "#/$defs/StringList"
    },
    "verification_methods": {
      "$ref": "#/$defs/StringList"
    },
    "guardrail_thresholds": {
      "$ref": "#/$defs/GuardrailThresholds"
    },
    "todos": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Todo"
      }
    },
    "attempt_ledger": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Attempt"
      }
    },
    "verification_evidence": {
      "$ref": "#/$defs/StringList"
    },
    "guardrail_scores": {
      "$ref": "#/$defs/GuardrailScores"
    },
    "blockers": {
      "$ref": "#/$defs/StringList"
    },
    "uigwe_reentry_requests": {
      "$ref": "#/$defs/StringList"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "format",
    "run_id",
    "repo_root",
    "provenance",
    "goal",
    "status",
    "success_criteria",
    "verification_methods",
    "guardrail_thresholds",
    "todos",
    "attempt_ledger",
    "verification_evidence",
    "guardrail_scores",
    "blockers",
    "uigwe_reentry_requests",
    "created_at",
    "updated_at"
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "source_repo": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "source_commit": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "skill_version": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "host": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "model": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "input_refs": {
          "$ref": "#/$defs/StringList"
        },
        "verification_refs": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "created_by",
        "source_repo",
        "source_commit",
        "skill_version",
        "host",
        "model",
        "generated_at",
        "input_refs",
        "verification_refs"
      ]
    },
    "ScoreValue": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "GuardrailScores": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ScoreValue"
      }
    },
    "GuardrailThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leaf_guardrail_minimum": {
          "$ref": "#/$defs/ScoreValue"
        },
        "leaf_guardrail_aggregate": {
          "$ref": "#/$defs/ScoreValue"
        },
        "run_guardrail_aggregate": {
          "$ref": "#/$defs/ScoreValue"
        },
        "selected_leaf_coverage": {
          "$ref": "#/$defs/ScoreValue"
        },
        "success_criteria_coverage": {
          "$ref": "#/$defs/ScoreValue"
        }
      },
      "required": [
        "leaf_guardrail_minimum",
        "leaf_guardrail_aggregate",
        "run_guardrail_aggregate",
        "selected_leaf_coverage",
        "success_criteria_coverage"
      ]
    },
    "TodoStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "blocked",
        "invalidated",
        "replaced"
      ]
    },
    "Todo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "todo_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "done_criteria": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "verification_method": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "guardrail_scores": {
          "$ref": "#/$defs/GuardrailScores"
        },
        "status": {
          "$ref": "#/$defs/TodoStatus"
        },
        "attempt_ids": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "todo_id",
        "description",
        "done_criteria",
        "verification_method",
        "guardrail_scores",
        "status",
        "attempt_ids"
      ]
    },
    "Attempt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "todo_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "hypothesis": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "action": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "verification": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "result": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "finding": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "next_decision": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "evidence_refs": {
          "$ref": "#/$defs/StringList"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "attempt_id",
        "todo_id",
        "hypothesis",
        "action",
        "verification",
        "result",
        "finding",
        "next_decision",
        "evidence_refs",
        "created_at"
      ]
    }
  }
}
