{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/validation.scorecard.schema.json",
  "title": "Uigwe Validation Scorecard Schema Draft",
  "description": "Scorecard for Uigwe frozen planning and instruction-surface benchmark runs.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "uigwe.validation-scorecard/v0.1-draft"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "aggregate": {
      "$ref": "#/$defs/Aggregate"
    },
    "scenario_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ScenarioResult"
      }
    },
    "notes": {
      "$ref": "#/$defs/StringList"
    }
  },
  "required": [
    "format",
    "metadata",
    "aggregate",
    "scenario_results",
    "notes"
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "Score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "Status": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail"
      ]
    },
    "SystemUnderTest": {
      "type": "string",
      "enum": [
        "baseline-lightweight",
        "baseline-structured",
        "uigwe",
        "sejong-uigwe"
      ]
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "task_set_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "system_under_test": {
          "$ref": "#/$defs/SystemUnderTest"
        },
        "runner": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "id",
        "task_set_id",
        "generated_at",
        "system_under_test",
        "runner"
      ]
    },
    "Aggregate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scenario_count": {
          "type": "integer",
          "minimum": 1
        },
        "pass_count": {
          "type": "integer",
          "minimum": 0
        },
        "partial_count": {
          "type": "integer",
          "minimum": 0
        },
        "fail_count": {
          "type": "integer",
          "minimum": 0
        },
        "average_score": {
          "$ref": "#/$defs/Score"
        },
        "meets_targets": {
          "type": "boolean"
        }
      },
      "required": [
        "scenario_count",
        "pass_count",
        "partial_count",
        "fail_count",
        "average_score",
        "meets_targets"
      ]
    },
    "Check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "missing": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "id",
        "passed",
        "detail"
      ]
    },
    "ScenarioResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scenario_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "score": {
          "$ref": "#/$defs/Score"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Check"
          }
        },
        "blockers": {
          "$ref": "#/$defs/StringList"
        },
        "notes": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "scenario_id",
        "title",
        "status",
        "score",
        "checks",
        "blockers",
        "notes"
      ]
    }
  }
}
