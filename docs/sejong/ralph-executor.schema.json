{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/ralph-executor.schema.json",
  "title": "Uigwe RalphExecutor Schema Draft",
  "description": "Draft request and result contract for handing an Uigwe bundle to RalphExecutor.",
  "oneOf": [
    {
      "$ref": "#/$defs/RalphExecutorRequest"
    },
    {
      "$ref": "#/$defs/RalphExecutorResult"
    }
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "DateTimeString": {
      "type": "string",
      "format": "date-time"
    },
    "PositiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "BundleFingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "Mode": {
      "type": "string",
      "enum": [
        "auto",
        "full",
        "design-to-plan",
        "decompose-only"
      ]
    },
    "Profile": {
      "type": "string",
      "enum": [
        "greenfield",
        "brownfield"
      ]
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "NonEmptyStringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "EmptyStringList": {
      "type": "array",
      "maxItems": 0,
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "CommitPolicyMode": {
      "type": "string",
      "enum": [
        "no_commit",
        "prepare_only",
        "create_commits"
      ]
    },
    "ExecutionStatus": {
      "type": "string",
      "enum": [
        "accepted",
        "in_progress",
        "completed",
        "blocked",
        "invalidated",
        "failed"
      ]
    },
    "ExecutionTrigger": {
      "type": "string",
      "enum": [
        "run_now",
        "follow_command",
        "harness",
        "rerun"
      ]
    },
    "RequestStatus": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "archived"
      ]
    },
    "HandoffArtifactDisposition": {
      "type": "string",
      "enum": [
        "active",
        "retained",
        "archived",
        "deleted"
      ]
    },
    "ReentryTarget": {
      "type": "string",
      "enum": [
        "none",
        "local_reexploration",
        "brainstorming",
        "deep_interview",
        "human_review"
      ]
    },
    "BundlePaths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plan_packet_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "goal_tree_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "spec_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "rationale_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "planning_summary_path": {
          "type": "string"
        }
      },
      "required": [
        "plan_packet_path",
        "goal_tree_path",
        "spec_path",
        "rationale_path"
      ]
    },
    "PlanningContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resolved_mode": {
          "$ref": "#/$defs/Mode"
        },
        "resolved_profile": {
          "$ref": "#/$defs/Profile"
        },
        "selected_plan_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "selected_plan_title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "selected_plan_summary": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "resolved_mode",
        "resolved_profile",
        "selected_plan_id",
        "selected_plan_title",
        "selected_plan_summary"
      ]
    },
    "ArchivedHandoffPaths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "archived_request_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "archived_next_step_path": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "archived_request_path",
        "archived_next_step_path"
      ]
    },
    "GitPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/CommitPolicyMode"
        },
        "verification_strategy": {
          "type": "string",
          "enum": [
            "tiered_changed_scope",
            "full_scope",
            "record_only"
          ]
        },
        "require_clean_start": {
          "type": "boolean"
        },
        "require_clean_finish": {
          "type": "boolean"
        },
        "target_repo_paths": {
          "$ref": "#/$defs/StringList"
        },
        "parent_repo_path": {
          "type": "string"
        },
        "parent_gitlink_policy": {
          "type": "string",
          "enum": [
            "none",
            "record_if_changed",
            "commit_after_target_repo_commit"
          ]
        }
      },
      "required": [
        "mode",
        "verification_strategy",
        "require_clean_finish"
      ]
    },
    "GitCommitGroup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "group_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "leaf_ids": {
          "$ref": "#/$defs/NonEmptyStringList"
        },
        "commit_shas": {
          "$ref": "#/$defs/NonEmptyStringList"
        },
        "summary": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "files_changed": {
          "$ref": "#/$defs/StringList"
        },
        "verification_tier": {
          "type": "string",
          "enum": [
            "tier_0",
            "tier_1",
            "tier_2",
            "tier_3",
            "tier_4"
          ]
        }
      },
      "required": [
        "group_id",
        "leaf_ids",
        "commit_shas",
        "summary"
      ]
    },
    "GitRepositoryEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "branch": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "head_before": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "head_after": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "remote_contains_head": {
          "type": "boolean"
        },
        "worktree_clean": {
          "const": true
        },
        "remaining_tracked_dirty_paths": {
          "$ref": "#/$defs/EmptyStringList"
        },
        "preexisting_dirty_paths": {
          "$ref": "#/$defs/StringList"
        },
        "commit_groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GitCommitGroup"
          }
        },
        "parent_gitlink_status": {
          "type": "string",
          "enum": [
            "not_applicable",
            "clean",
            "committed",
            "blocked"
          ]
        },
        "verification_summary": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "repo_path",
        "branch",
        "head_before",
        "head_after",
        "worktree_clean",
        "remaining_tracked_dirty_paths",
        "commit_groups",
        "verification_summary"
      ]
    },
    "GitEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy_mode": {
          "$ref": "#/$defs/CommitPolicyMode"
        },
        "repositories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/GitRepositoryEvidence"
          }
        }
      },
      "required": [
        "policy_mode",
        "repositories"
      ]
    },
    "ExecutionScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selection_mode": {
          "type": "string",
          "enum": [
            "all_executable_leaves",
            "selected_leaf_ids"
          ]
        },
        "executable_leaf_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          }
        },
        "ordered_leaf_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          }
        }
      },
      "required": [
        "selection_mode",
        "executable_leaf_ids",
        "ordered_leaf_ids"
      ]
    },
    "NextStepAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "action_type": {
          "type": "string",
          "enum": [
            "run_now",
            "show_command"
          ]
        },
        "command": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "label",
        "description",
        "action_type"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "show_command"
              }
            }
          },
          "then": {
            "required": [
              "command"
            ]
          }
        }
      ]
    },
    "NextStepOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "1": {
          "$ref": "#/$defs/NextStepAction"
        },
        "3": {
          "$ref": "#/$defs/NextStepAction"
        }
      },
      "required": [
        "1",
        "3"
      ]
    },
    "RalphExecutorRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "enum": [
            "uigwe.ralph-executor-request/v0.3-draft",
            "uigwe.ralph-executor-request/v0.4-draft"
          ]
        },
        "executor_type": {
          "const": "ralph"
        },
        "backend": {
          "const": "codex-native-ralph-skill"
        },
        "bundle_root_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "bundle": {
          "$ref": "#/$defs/BundlePaths"
        },
        "attempt_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "attempt_number": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "request_generated_at": {
          "$ref": "#/$defs/DateTimeString"
        },
        "request_status": {
          "$ref": "#/$defs/RequestStatus"
        },
        "bundle_fingerprint": {
          "$ref": "#/$defs/BundleFingerprint"
        },
        "supersedes_attempt_id": {
          "type": "string"
        },
        "planning_context": {
          "$ref": "#/$defs/PlanningContext"
        },
        "execution_scope": {
          "$ref": "#/$defs/ExecutionScope"
        },
        "source_of_truth": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "plan_packet",
              "goal_tree",
              "spec",
              "rationale",
              "planning_summary"
            ]
          }
        },
        "allow_replanning": {
          "const": false
        },
        "git_policy": {
          "$ref": "#/$defs/GitPolicy"
        },
        "allowed_reentry_targets": {
          "$ref": "#/$defs/StringList"
        },
        "execution_rules": {
          "$ref": "#/$defs/StringList"
        },
        "output_expectations": {
          "$ref": "#/$defs/StringList"
        },
        "recommended_next_command": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "next_step_options": {
          "$ref": "#/$defs/NextStepOptions"
        },
        "next_step_message": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "handoff_prompt": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "suggested_handoff_prompt_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "suggested_execution_feedback_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "suggested_result_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "notes": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "format",
        "executor_type",
        "backend",
        "bundle_root_path",
        "bundle",
        "attempt_id",
        "attempt_number",
        "request_generated_at",
        "request_status",
        "bundle_fingerprint",
        "planning_context",
        "execution_scope",
        "source_of_truth",
        "allow_replanning",
        "allowed_reentry_targets",
        "execution_rules",
        "output_expectations",
        "recommended_next_command",
        "next_step_options",
        "next_step_message",
        "handoff_prompt",
        "suggested_handoff_prompt_path",
        "suggested_execution_feedback_path",
        "suggested_result_path",
        "notes"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "format": {
                "const": "uigwe.ralph-executor-request/v0.4-draft"
              }
            }
          },
          "then": {
            "required": [
              "git_policy"
            ]
          }
        }
      ]
    },
    "RalphExecutorResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "enum": [
            "uigwe.ralph-executor-result/v0.3-draft",
            "uigwe.ralph-executor-result/v0.4-draft"
          ]
        },
        "executor_type": {
          "const": "ralph"
        },
        "backend": {
          "const": "codex-native-ralph-skill"
        },
        "attempt_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "attempt_number": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "trigger": {
          "$ref": "#/$defs/ExecutionTrigger"
        },
        "started_at": {
          "$ref": "#/$defs/DateTimeString"
        },
        "finished_at": {
          "$ref": "#/$defs/DateTimeString"
        },
        "status": {
          "$ref": "#/$defs/ExecutionStatus"
        },
        "bundle": {
          "$ref": "#/$defs/BundlePaths"
        },
        "bundle_fingerprint": {
          "$ref": "#/$defs/BundleFingerprint"
        },
        "execution_feedback_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "recommended_reentry_target": {
          "$ref": "#/$defs/ReentryTarget"
        },
        "git_policy": {
          "$ref": "#/$defs/GitPolicy"
        },
        "git_evidence": {
          "$ref": "#/$defs/GitEvidence"
        },
        "handoff_artifact_disposition": {
          "$ref": "#/$defs/HandoffArtifactDisposition"
        },
        "archived_handoff_paths": {
          "$ref": "#/$defs/ArchivedHandoffPaths"
        },
        "notes": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "format",
        "executor_type",
        "backend",
        "attempt_id",
        "attempt_number",
        "trigger",
        "started_at",
        "status",
        "bundle",
        "bundle_fingerprint",
        "execution_feedback_path",
        "recommended_reentry_target",
        "handoff_artifact_disposition",
        "notes"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "format": {
                "const": "uigwe.ralph-executor-result/v0.4-draft"
              }
            }
          },
          "then": {
            "required": [
              "git_policy"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "completed",
                  "blocked",
                  "invalidated",
                  "failed"
                ]
              }
            }
          },
          "then": {
            "required": [
              "finished_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "accepted",
                  "in_progress",
                  "completed"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "recommended_reentry_target": {
                "const": "none"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status",
              "git_policy"
            ],
            "properties": {
              "status": {
                "const": "completed"
              },
              "git_policy": {
                "required": [
                  "mode"
                ],
                "properties": {
                  "mode": {
                    "const": "create_commits"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "git_evidence"
            ]
          }
        },
        {
          "if": {
            "required": [
              "git_policy",
              "git_evidence"
            ],
            "properties": {
              "git_policy": {
                "required": [
                  "mode"
                ],
                "properties": {
                  "mode": {
                    "const": "create_commits"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "git_evidence": {
                "properties": {
                  "policy_mode": {
                    "const": "create_commits"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "git_policy",
              "git_evidence"
            ],
            "properties": {
              "git_policy": {
                "required": [
                  "mode"
                ],
                "properties": {
                  "mode": {
                    "const": "prepare_only"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "git_evidence": {
                "properties": {
                  "policy_mode": {
                    "const": "prepare_only"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "git_policy",
              "git_evidence"
            ],
            "properties": {
              "git_policy": {
                "required": [
                  "mode"
                ],
                "properties": {
                  "mode": {
                    "const": "no_commit"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "git_evidence": {
                "properties": {
                  "policy_mode": {
                    "const": "no_commit"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "handoff_artifact_disposition": {
                "const": "archived"
              }
            }
          },
          "then": {
            "required": [
              "archived_handoff_paths"
            ]
          }
        }
      ]
    }
  }
}
