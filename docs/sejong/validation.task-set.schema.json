{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/validation.task-set.schema.json",
  "title": "Uigwe Validation Task Set Schema Draft",
  "description": "Frozen scenario set for Uigwe planning and instruction-surface benchmarks.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "uigwe.validation-task-set/v0.1-draft"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Scenario"
      }
    }
  },
  "required": [
    "format",
    "metadata",
    "scenarios"
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "Mode": {
      "type": "string",
      "enum": [
        "auto",
        "full",
        "design-to-plan",
        "decompose-only",
        "none"
      ]
    },
    "Profile": {
      "type": "string",
      "enum": [
        "greenfield",
        "brownfield",
        "mixed",
        "instruction",
        "sejong",
        "routing",
        "research",
        "decision",
        "planning",
        "execution",
        "team",
        "continuity",
        "guardrail"
      ]
    },
    "Surface": {
      "type": "string",
      "enum": [
        "sejong",
        "jangyeongsil",
        "jiphyeonjeon",
        "uigwe",
        "seungjeongwon",
        "sillok",
        "danjong",
        "sejong-direct"
      ]
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "purpose": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "created_at": {
          "type": "string",
          "format": "date"
        }
      },
      "required": [
        "id",
        "title",
        "purpose",
        "created_at"
      ]
    },
    "Scenario": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "profile": {
          "$ref": "#/$defs/Profile"
        },
        "input_shape": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "prompt": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "expected_mode": {
          "$ref": "#/$defs/Mode"
        },
        "expected_artifacts": {
          "$ref": "#/$defs/StringList"
        },
        "expected_behavior": {
          "$ref": "#/$defs/StringList"
        },
        "forbidden_behavior": {
          "$ref": "#/$defs/StringList"
        },
        "grading_notes": {
          "$ref": "#/$defs/StringList"
        },
        "guardrail_expectations": {
          "$ref": "#/$defs/GuardrailExpectations"
        },
        "expected_route_sequence": {
          "$ref": "#/$defs/StringList"
        },
        "acceptable_route_sequences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StringList"
          }
        },
        "forbidden_surfaces": {
          "$ref": "#/$defs/StringList"
        },
        "clarification_required": {
          "type": "boolean"
        },
        "resource_expectations": {
          "$ref": "#/$defs/ResourceExpectations"
        }
      },
      "required": [
        "id",
        "title",
        "profile",
        "input_shape",
        "prompt",
        "expected_mode",
        "expected_artifacts",
        "expected_behavior",
        "forbidden_behavior",
        "grading_notes"
      ]
    },
    "GuardrailExpectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_state_fields": {
          "$ref": "#/$defs/StringList"
        },
        "exit_conditions": {
          "$ref": "#/$defs/StringList"
        },
        "protected_paths": {
          "$ref": "#/$defs/StringList"
        },
        "required_route_sequence": {
          "$ref": "#/$defs/StringList"
        },
        "allowed_direct_change_types": {
          "$ref": "#/$defs/StringList"
        },
        "pending_gates": {
          "$ref": "#/$defs/StringList"
        },
        "blocked_surfaces": {
          "$ref": "#/$defs/StringList"
        },
        "promotion_gate": {
          "$ref": "#/$defs/StringList"
        },
        "hook_enforcement": {
          "$ref": "#/$defs/StringList"
        },
        "worker_authority_forbidden_claims": {
          "$ref": "#/$defs/StringList"
        },
        "artifact_retention_policy": {
          "$ref": "#/$defs/StringList"
        },
        "repo_context_guardrails": {
          "$ref": "#/$defs/StringList"
        },
        "decision_justification_fields": {
          "$ref": "#/$defs/StringList"
        },
        "ownership_boundaries": {
          "$ref": "#/$defs/StringList"
        },
        "task_class_promotion": {
          "$ref": "#/$defs/StringList"
        },
        "strict_promotion_evidence": {
          "$ref": "#/$defs/StringList"
        },
        "defect_first_review": {
          "$ref": "#/$defs/StringList"
        }
      }
    },
    "ResourceExpectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_turns": {
          "type": "integer",
          "minimum": 1
        },
        "max_tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "max_total_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "max_wall_time_sec": {
          "type": "number",
          "minimum": 0
        },
        "overhead_budget_note": {
          "$ref": "#/$defs/NonEmptyString"
        }
      }
    }
  }
}
