{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/validation.task-set.schema.json",
  "title": "Uigwe Validation Task Set Schema Draft",
  "description": "Frozen scenario set for Uigwe planning and instruction-surface benchmarks.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "uigwe.validation-task-set/v0.1-draft"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Scenario"
      }
    }
  },
  "required": [
    "format",
    "metadata",
    "scenarios"
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "Mode": {
      "type": "string",
      "enum": [
        "auto",
        "full",
        "design-to-plan",
        "decompose-only",
        "none"
      ]
    },
    "Profile": {
      "type": "string",
      "enum": [
        "greenfield",
        "brownfield",
        "mixed",
        "instruction"
      ]
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "purpose": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "created_at": {
          "type": "string",
          "format": "date"
        }
      },
      "required": [
        "id",
        "title",
        "purpose",
        "created_at"
      ]
    },
    "Scenario": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "profile": {
          "$ref": "#/$defs/Profile"
        },
        "input_shape": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "prompt": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "expected_mode": {
          "$ref": "#/$defs/Mode"
        },
        "expected_artifacts": {
          "$ref": "#/$defs/StringList"
        },
        "expected_behavior": {
          "$ref": "#/$defs/StringList"
        },
        "forbidden_behavior": {
          "$ref": "#/$defs/StringList"
        },
        "grading_notes": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "id",
        "title",
        "profile",
        "input_shape",
        "prompt",
        "expected_mode",
        "expected_artifacts",
        "expected_behavior",
        "forbidden_behavior",
        "grading_notes"
      ]
    }
  }
}
