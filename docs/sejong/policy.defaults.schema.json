{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/policy.defaults.schema.json",
  "title": "Sejong Planning And Execution Policy Defaults Schema Draft",
  "description": "Draft schema for Uigwe handoff-readiness and Seungjeongwon actionable-readiness default policy values.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "uigwe.policy-defaults/v0.1-draft"
    },
    "derived_metrics": {
      "$ref": "#/$defs/DerivedMetrics"
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "greenfield": {
          "$ref": "#/$defs/ProfilePolicy"
        },
        "brownfield": {
          "$ref": "#/$defs/ProfilePolicy"
        }
      },
      "required": [
        "greenfield",
        "brownfield"
      ]
    },
    "artifact_retention": {
      "$ref": "#/$defs/ArtifactRetention"
    }
  },
  "required": [
    "format",
    "derived_metrics",
    "profiles",
    "artifact_retention"
  ],
  "$defs": {
    "Weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "IntegerThreshold": {
      "type": "integer",
      "minimum": 0
    },
    "StringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "NameList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "DimensionWeights": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/Weight"
      }
    },
    "CandidatePriorityMetric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formula": {
          "const": "weighted_sum"
        },
        "notes": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "formula",
        "notes"
      ]
    },
    "DerivedMetric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimensions": {
          "$ref": "#/$defs/DimensionWeights"
        }
      },
      "required": [
        "dimensions"
      ]
    },
    "DerivedMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_priority_score": {
          "$ref": "#/$defs/CandidatePriorityMetric"
        },
        "intent_readiness": {
          "$ref": "#/$defs/DerivedMetric"
        },
        "design_readiness": {
          "$ref": "#/$defs/DerivedMetric"
        },
        "handoff_readiness": {
          "$ref": "#/$defs/DerivedMetric"
        },
        "actionable_readiness": {
          "$ref": "#/$defs/DerivedMetric"
        },
        "execution_guardrail_score": {
          "$ref": "#/$defs/DerivedMetric"
        }
      },
      "required": [
        "candidate_priority_score",
        "intent_readiness",
        "design_readiness",
        "handoff_readiness",
        "actionable_readiness",
        "execution_guardrail_score"
      ]
    },
    "CandidateScoreWeights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "goal_contribution": {
          "$ref": "#/$defs/Weight"
        },
        "confidence": {
          "$ref": "#/$defs/Weight"
        },
        "verification_clarity": {
          "$ref": "#/$defs/Weight"
        },
        "dependency_simplicity": {
          "$ref": "#/$defs/Weight"
        },
        "cost_efficiency": {
          "$ref": "#/$defs/Weight"
        },
        "risk_efficiency": {
          "$ref": "#/$defs/Weight"
        }
      },
      "required": [
        "goal_contribution",
        "confidence",
        "verification_clarity",
        "dependency_simplicity",
        "cost_efficiency",
        "risk_efficiency"
      ]
    },
    "ReadinessThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "intent_to_brainstorming": {
          "$ref": "#/$defs/Weight"
        },
        "design_to_decomposition": {
          "$ref": "#/$defs/Weight"
        },
        "handoff_to_seungjeongwon": {
          "$ref": "#/$defs/Weight"
        },
        "actionable_to_execution": {
          "$ref": "#/$defs/Weight"
        }
      },
      "required": [
        "intent_to_brainstorming",
        "design_to_decomposition",
        "handoff_to_seungjeongwon",
        "actionable_to_execution"
      ]
    },
    "BeamWidths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "0": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "1": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "2": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "3+": {
          "$ref": "#/$defs/IntegerThreshold"
        }
      },
      "required": [
        "0",
        "1",
        "2",
        "3+"
      ]
    },
    "FrontierPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "beam_width_by_depth": {
          "$ref": "#/$defs/BeamWidths"
        },
        "retained_alternatives_by_depth": {
          "$ref": "#/$defs/BeamWidths"
        },
        "max_candidates_per_node": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "local_retry_limit": {
          "$ref": "#/$defs/IntegerThreshold"
        }
      },
      "required": [
        "beam_width_by_depth",
        "retained_alternatives_by_depth",
        "max_candidates_per_node",
        "local_retry_limit"
      ]
    },
    "ReentryThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local_score_advantage": {
          "$ref": "#/$defs/Weight"
        },
        "brainstorming_score_advantage": {
          "$ref": "#/$defs/Weight"
        },
        "subtree_blocked_or_invalidated_ratio": {
          "$ref": "#/$defs/Weight"
        },
        "upstream_assumption_invalidations": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "max_brainstorming_reentries_before_deep_interview": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "non_goal_contradictions_force_deep_interview": {
          "type": "boolean"
        },
        "decision_boundary_contradictions_force_deep_interview": {
          "type": "boolean"
        }
      },
      "required": [
        "local_score_advantage",
        "brainstorming_score_advantage",
        "subtree_blocked_or_invalidated_ratio",
        "upstream_assumption_invalidations",
        "max_brainstorming_reentries_before_deep_interview",
        "non_goal_contradictions_force_deep_interview",
        "decision_boundary_contradictions_force_deep_interview"
      ]
    },
    "CompletionThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leaf_guardrail_minimum": {
          "$ref": "#/$defs/Weight"
        },
        "leaf_guardrail_aggregate": {
          "$ref": "#/$defs/Weight"
        },
        "run_guardrail_aggregate": {
          "$ref": "#/$defs/Weight"
        },
        "selected_leaf_coverage": {
          "$ref": "#/$defs/Weight"
        },
        "success_criteria_coverage": {
          "$ref": "#/$defs/Weight"
        },
        "hard_guardrails_required": {
          "type": "boolean"
        }
      },
      "required": [
        "leaf_guardrail_minimum",
        "leaf_guardrail_aggregate",
        "run_guardrail_aggregate",
        "selected_leaf_coverage",
        "success_criteria_coverage",
        "hard_guardrails_required"
      ]
    },
    "ProfilePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_score_weights": {
          "$ref": "#/$defs/CandidateScoreWeights"
        },
        "readiness_thresholds": {
          "$ref": "#/$defs/ReadinessThresholds"
        },
        "frontier_policy": {
          "$ref": "#/$defs/FrontierPolicy"
        },
        "reentry_thresholds": {
          "$ref": "#/$defs/ReentryThresholds"
        },
        "completion_thresholds": {
          "$ref": "#/$defs/CompletionThresholds"
        }
      },
      "required": [
        "candidate_score_weights",
        "readiness_thresholds",
        "frontier_policy",
        "reentry_thresholds",
        "completion_thresholds"
      ]
    },
    "ArtifactRetention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_profile": {
          "const": "standard"
        },
        "profiles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "standard": {
              "$ref": "#/$defs/ArtifactRetentionProfile"
            }
          },
          "required": [
            "standard"
          ]
        }
      },
      "required": [
        "default_profile",
        "profiles"
      ]
    },
    "ArtifactRetentionProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "success_raw_ttl_days": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "failed_raw_ttl_days": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "blocked_raw_ttl_days": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "compact_ttl_days": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "max_compact_runs_per_repo": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "sensitive_raw_ttl_hours": {
          "$ref": "#/$defs/IntegerThreshold"
        },
        "dry_run_by_default": {
          "type": "boolean"
        },
        "delete_requires_execute": {
          "type": "boolean"
        },
        "active_context_protection": {
          "type": "boolean"
        },
        "compact_keep_names": {
          "$ref": "#/$defs/NameList"
        },
        "promoted_marker_names": {
          "$ref": "#/$defs/NameList"
        }
      },
      "required": [
        "success_raw_ttl_days",
        "failed_raw_ttl_days",
        "blocked_raw_ttl_days",
        "compact_ttl_days",
        "max_compact_runs_per_repo",
        "sensitive_raw_ttl_hours",
        "dry_run_by_default",
        "delete_requires_execute",
        "active_context_protection",
        "compact_keep_names",
        "promoted_marker_names"
      ]
    }
  }
}
