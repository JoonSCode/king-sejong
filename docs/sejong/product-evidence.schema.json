{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/sejong/product-evidence.schema.json",
  "title": "Sejong Product Evidence Gate Schema Draft",
  "oneOf": [
    {
      "$ref": "#/$defs/Plan"
    },
    {
      "$ref": "#/$defs/Result"
    },
    {
      "$ref": "#/$defs/Judgment"
    }
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "MetricRequirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metric_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "metric_id",
        "description"
      ]
    },
    "AnalyticsRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accepted_source_types": {
          "$ref": "#/$defs/StringList"
        },
        "required_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/MetricRequirement"
          }
        }
      },
      "required": [
        "accepted_source_types",
        "required_metrics"
      ]
    },
    "ExperimentPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variants": {
          "$ref": "#/$defs/StringList"
        },
        "assignment_unit": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "primary_metric_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "minimum_sample_per_variant": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_duration_days": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_effect": {
          "type": "number",
          "minimum": 0
        },
        "guardrail_metrics": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "variants",
        "assignment_unit",
        "primary_metric_id",
        "minimum_sample_per_variant",
        "minimum_duration_days",
        "minimum_effect",
        "guardrail_metrics"
      ]
    },
    "UserResearchPlan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "segment": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "minimum_participants": {
          "type": "integer",
          "minimum": 1
        },
        "required_outputs": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "segment",
        "minimum_participants",
        "required_outputs"
      ]
    },
    "Plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "const": "sejong.product-evidence-plan/v0.1-draft"
        },
        "task_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "claim_under_test": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "success_claim_policy": {
          "const": "no_success_claim_without_external_result"
        },
        "evidence_classes": {
          "$ref": "#/$defs/StringList"
        },
        "analytics_requirements": {
          "$ref": "#/$defs/AnalyticsRequirements"
        },
        "controlled_experiment": {
          "$ref": "#/$defs/ExperimentPlan"
        },
        "user_research": {
          "$ref": "#/$defs/UserResearchPlan"
        }
      },
      "required": [
        "format",
        "task_id",
        "claim_under_test",
        "success_claim_policy",
        "evidence_classes",
        "analytics_requirements",
        "controlled_experiment",
        "user_research"
      ]
    },
    "MetricValue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseline": {
          "type": "number"
        },
        "candidate": {
          "type": "number"
        },
        "relative_delta": {
          "type": "number"
        }
      },
      "required": [
        "baseline",
        "candidate",
        "relative_delta"
      ]
    },
    "AnalyticsResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/MetricValue"
          }
        }
      },
      "required": [
        "source_type",
        "metrics"
      ]
    },
    "VariantResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "sample_size"
      ]
    },
    "ExperimentResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VariantResult"
          }
        },
        "duration_days": {
          "type": "integer",
          "minimum": 0
        },
        "primary_metric_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "observed_effect": {
          "type": "number"
        },
        "winner": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "guardrail_regressions": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "variants",
        "duration_days",
        "primary_metric_id",
        "observed_effect",
        "winner",
        "guardrail_regressions"
      ]
    },
    "UserResearchResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "segment": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "participants": {
          "type": "integer",
          "minimum": 0
        },
        "findings": {
          "$ref": "#/$defs/StringList"
        },
        "contradictions": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "segment",
        "participants",
        "findings",
        "contradictions"
      ]
    },
    "Result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "const": "sejong.product-evidence-result/v0.1-draft"
        },
        "task_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "result_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "collected_at": {
          "type": "string",
          "format": "date-time"
        },
        "external_evidence_refs": {
          "$ref": "#/$defs/StringList"
        },
        "analytics": {
          "$ref": "#/$defs/AnalyticsResult"
        },
        "controlled_experiment": {
          "$ref": "#/$defs/ExperimentResult"
        },
        "user_research": {
          "$ref": "#/$defs/UserResearchResult"
        }
      },
      "required": [
        "format",
        "task_id",
        "result_id",
        "collected_at",
        "external_evidence_refs",
        "analytics",
        "controlled_experiment",
        "user_research"
      ]
    },
    "Judgment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "format": {
          "const": "sejong.product-evidence-judgment/v0.1-draft"
        }
      },
      "required": [
        "format"
      ]
    }
  }
}
