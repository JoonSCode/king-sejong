{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinno.dev/schemas/uigwe/codex-consumer-feedback.schema.json",
  "title": "Uigwe Codex Consumer Feedback Schema Draft",
  "description": "Draft machine-readable feedback contract for the default Uigwe Codex consumer.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "uigwe.codex-consumer-feedback/v0.2-draft"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "summary": {
      "$ref": "#/$defs/Summary"
    },
    "leaf_updates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/LeafUpdate"
      }
    },
    "visible_todo_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/VisibleTodoEvent"
      }
    },
    "verification_perspectives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/VerificationPerspective"
      }
    },
    "paired_result_comparison": {
      "$ref": "#/$defs/PairedResultComparison"
    },
    "escalations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Escalation"
      }
    }
  },
  "required": [
    "format",
    "metadata",
    "summary",
    "leaf_updates",
    "visible_todo_events",
    "escalations"
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "DateTimeString": {
      "type": "string",
      "format": "date-time"
    },
    "PositiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "BundleFingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "StringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NonEmptyString"
      }
    },
    "Profile": {
      "type": "string",
      "enum": [
        "greenfield",
        "brownfield"
      ]
    },
    "NodeStatus": {
      "type": "string",
      "enum": [
        "candidate",
        "selected",
        "retained_alt",
        "handoff_leaf",
        "actionable_leaf",
        "dispatched",
        "completed",
        "blocked",
        "invalidated"
      ]
    },
    "ExecutionLane": {
      "type": "string",
      "enum": [
        "direct_session",
        "single_subagent",
        "reviewed_subagent"
      ]
    },
    "VisibleTodoEventType": {
      "type": "string",
      "enum": [
        "publish",
        "start",
        "verify",
        "redefine",
        "replace",
        "complete",
        "block",
        "board_unavailable"
      ]
    },
    "VisibleTodoStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "blocked",
        "invalidated",
        "replaced",
        "unavailable"
      ]
    },
    "ReentryTarget": {
      "type": "string",
      "enum": [
        "none",
        "local_reexploration",
        "brainstorming",
        "deep_interview",
        "human_review"
      ]
    },
    "PerspectiveStatus": {
      "type": "string",
      "enum": [
        "sufficient",
        "weak",
        "split",
        "replaced",
        "escalated"
      ]
    },
    "ComparisonWinner": {
      "type": "string",
      "enum": [
        "baseline",
        "candidate",
        "tie",
        "inconclusive"
      ]
    },
    "ComparisonRecommendation": {
      "type": "string",
      "enum": [
        "promote_candidate",
        "reject_candidate",
        "keep_shadowing",
        "inconclusive"
      ]
    },
    "Metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "$ref": "#/$defs/Profile"
        },
        "generated_at": {
          "$ref": "#/$defs/DateTimeString"
        },
        "consumer": {
          "const": "codex"
        },
        "plan_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "goal_tree_path": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "attempt_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "attempt_number": {
          "$ref": "#/$defs/PositiveInteger"
        },
        "bundle_fingerprint": {
          "$ref": "#/$defs/BundleFingerprint"
        },
        "executor_result_path": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "profile",
        "generated_at",
        "consumer",
        "plan_id",
        "goal_tree_path",
        "attempt_id",
        "attempt_number",
        "bundle_fingerprint",
        "executor_result_path"
      ]
    },
    "Summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "completed_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalidated_count": {
          "type": "integer",
          "minimum": 0
        },
        "requires_planner_reentry": {
          "type": "boolean"
        },
        "recommended_reentry_target": {
          "$ref": "#/$defs/ReentryTarget"
        }
      },
      "required": [
        "completed_count",
        "blocked_count",
        "invalidated_count",
        "requires_planner_reentry",
        "recommended_reentry_target"
      ]
    },
    "EvidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "required": [
        "type",
        "description"
      ]
    },
    "GuardrailScores": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "LeafUpdate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "previous_status": {
          "$ref": "#/$defs/NodeStatus"
        },
        "new_status": {
          "$ref": "#/$defs/NodeStatus"
        },
        "execution_lane": {
          "$ref": "#/$defs/ExecutionLane"
        },
        "artifacts": {
          "$ref": "#/$defs/StringList"
        },
        "commit_group_ids": {
          "$ref": "#/$defs/StringList"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceItem"
          }
        },
        "guardrail_scores": {
          "$ref": "#/$defs/GuardrailScores"
        },
        "notes": {
          "type": "string"
        },
        "recommended_reentry_target": {
          "$ref": "#/$defs/ReentryTarget"
        }
      },
      "required": [
        "node_id",
        "previous_status",
        "new_status",
        "execution_lane",
        "artifacts",
        "evidence",
        "recommended_reentry_target"
      ]
    },
    "VisibleTodoEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "event_type": {
          "$ref": "#/$defs/VisibleTodoEventType"
        },
        "todo_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "related_todo_ids": {
          "$ref": "#/$defs/StringList"
        },
        "summary": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/VisibleTodoStatus"
        },
        "reason": {
          "type": "string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/StringList"
        }
      },
      "required": [
        "event_id",
        "event_type",
        "todo_id",
        "related_todo_ids",
        "summary",
        "status",
        "evidence_refs"
      ]
    },
    "VerificationPerspective": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "perspective_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "question": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "evidence_target": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "method": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "sufficiency_threshold": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "falsification_signal": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "owner_boundary": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/PerspectiveStatus"
        },
        "evidence_refs": {
          "$ref": "#/$defs/StringList"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "perspective_id",
        "question",
        "evidence_target",
        "method",
        "sufficiency_threshold",
        "falsification_signal",
        "owner_boundary",
        "status",
        "evidence_refs"
      ]
    },
    "ComparisonDimension": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "baseline_result": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "candidate_result": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "winner": {
          "$ref": "#/$defs/ComparisonWinner"
        },
        "evidence_refs": {
          "$ref": "#/$defs/StringList"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "dimension",
        "baseline_result",
        "candidate_result",
        "winner",
        "evidence_refs"
      ]
    },
    "PairedResultComparison": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comparison_id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "baseline_label": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "candidate_label": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "same_starting_evidence": {
          "type": "boolean"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/StringList"
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ComparisonDimension"
          }
        },
        "unsupported_claim_count_baseline": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_claim_count_candidate": {
          "type": "integer",
          "minimum": 0
        },
        "final_recommendation": {
          "$ref": "#/$defs/ComparisonRecommendation"
        },
        "rationale": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "overhead_notes": {
          "type": "string"
        }
      },
      "required": [
        "comparison_id",
        "baseline_label",
        "candidate_label",
        "same_starting_evidence",
        "acceptance_criteria",
        "dimensions",
        "unsupported_claim_count_baseline",
        "unsupported_claim_count_candidate",
        "final_recommendation",
        "rationale"
      ]
    },
    "Escalation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "related_node_ids": {
          "$ref": "#/$defs/StringList"
        },
        "recommended_reentry_target": {
          "$ref": "#/$defs/ReentryTarget"
        }
      },
      "required": [
        "reason",
        "severity",
        "related_node_ids",
        "recommended_reentry_target"
      ]
    }
  }
}
